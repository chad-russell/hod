#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage: scripts/hod-ublue-build [options]

Build a Hod OS desktop image derived from UBlue base-main.

The resulting image includes a full niri Wayland desktop built entirely
by Hod from source, layered on top of UBlue's base system (kernel,
systemd, glibc, basic userland, bootc infrastructure).

Steps:
  1. Pull or reuse the UBlue base-main image.
  2. Build the niri-desktop Hod profile and materialize a generation.
  3. Copy the full transitive closure into a staging tree.
  4. Rewrite symlinks so they point at /usr/hod/store/... inside the image.
  5. Generate a derived Containerfile with desktop session setup.
  6. Build the derived OCI image with rootless podman.

Options:
  --profile <path>       Hod profile .ts file (default: profiles/niri-desktop.ts)
  --base-tag <tag>       Tag for the base image (default: base-main:latest)
  --image-tag <tag>      Tag for the derived image (default: hod-ublue:latest)
  --ssh-pubkey <path>    SSH public key to authorize for root
  --skip-base-pull       Skip pulling the base image (reuse existing)
  --skip-profile-build   Skip building the Hod profile (reuse existing generation)
  --stage-only           Stop after staging (skip Containerfile generation + podman build)
  --state-dir <dir>      Build state directory (default: .hod-vm/ublue)
  --hod-bin <path>       Path to hod binary (default: target/debug/hod or hod)
  -h, --help             Show this help

Examples:
  # Full build from scratch
  scripts/hod-ublue-build

  # Rebuild after profile change
  scripts/hod-ublue-build --skip-base-pull

  # Quick iteration (reuse profile + base)
  scripts/hod-ublue-build --skip-base-pull --skip-profile-build
USAGE
}

profile_path=""
base_tag="base-main:latest"
image_tag="hod-ublue:latest"
skip_base_pull=false
skip_profile_build=false
stage_only=false
state_dir=""
hod_bin_override=""
ssh_pubkey=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)       profile_path="$2"; shift 2 ;;
    --base-tag)      base_tag="$2"; shift 2 ;;
    --image-tag)     image_tag="$2"; shift 2 ;;
    --ssh-pubkey)    ssh_pubkey="$2"; shift 2 ;;
    --skip-base-pull)     skip_base_pull=true; shift ;;
    --skip-profile-build) skip_profile_build=true; shift ;;
    --stage-only)         stage_only=true; shift ;;
    --state-dir)     state_dir="$2"; shift 2 ;;
    --hod-bin)       hod_bin_override="$2"; shift 2 ;;
    -h|--help)       usage; exit 0 ;;
    *) printf 'Unknown option: %s\n' "$1" >&2; usage; exit 2 ;;
  esac
done

resolve_hod() {
  if [[ -n "${hod_bin_override:-}" ]]; then
    realpath "$hod_bin_override"
  elif [[ -x target/debug/hod ]]; then
    realpath target/debug/hod
  else
    command -v hod
  fi
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'hod-ublue-build: missing %s; run inside `nix develop --accept-flake-config`\n' "$1" >&2
    exit 1
  fi
}

need podman

hod_bin=$(resolve_hod)
state_dir=${state_dir:-.hod-vm/ublue}
profile_path=${profile_path:-systems/vm-desktop.ts}
staging_dir=$state_dir/staging
store_staging=$staging_dir/hod-store
system_staging=$staging_dir/hod-system
setup_staging=$staging_dir/setup
containerfile=$staging_dir/Containerfile
image_store=/usr/hod/store

mkdir -p "$state_dir" "$staging_dir"

host_store_root=$("$hod_bin" store-root)

ssh_pubkey_text=""
if [[ -n "$ssh_pubkey" && -f "$ssh_pubkey" ]]; then
  ssh_pubkey_text=$(<"$ssh_pubkey")
else
  for candidate in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub"; do
    if [[ -f "$candidate" ]]; then
      ssh_pubkey_text=$(<"$candidate")
      break
    fi
  done
fi

# ---------------------------------------------------------------------------
# 1. UBlue base-main image
# ---------------------------------------------------------------------------
base_ref="ghcr.io/ublue-os/base-main:latest"

if [[ "$skip_base_pull" == false ]]; then
  printf '[hod-ublue] pulling %s\n' "$base_ref" >&2
  podman pull --dns 8.8.8.8 --dns 1.1.1.1 "$base_ref" || \
    podman pull "$base_ref"
fi

if ! podman image exists "$base_tag" 2>/dev/null; then
  podman tag "$base_ref" "$base_tag"
fi

printf '[hod-ublue] base image: %s\n' "$base_tag" >&2

# ---------------------------------------------------------------------------
# 2. Build and activate Hod profile
# ---------------------------------------------------------------------------
if [[ "$skip_profile_build" == false ]]; then
  if [[ ! -f "$profile_path" ]]; then
    printf 'hod-ublue-build: profile not found: %s\n' "$profile_path" >&2
    exit 1
  fi

  printf '[hod-ublue] building profile from %s\n' "$profile_path" >&2
  "$hod_bin" system activate "$profile_path" --quiet
  printf '[hod-ublue] profile activated\n' >&2
else
  printf '[hod-ublue] skipping profile build (--skip-profile-build)\n' >&2
fi

gen_number=$("$hod_bin" system list 2>/dev/null | awk '/^\*/ { print $2 }' | head -1)
if [[ -z "$gen_number" ]]; then
  printf 'hod-ublue-build: no active system generation; run hod system activate first\n' >&2
  exit 1
fi

hod_sys_dir=${HOD_SYSTEM_DIR:-}
if [[ -z "$hod_sys_dir" ]]; then
  xdg=${XDG_DATA_HOME:-$HOME/.local/share}
  hod_sys_dir=$xdg/hod/system
fi
gen_dir=$hod_sys_dir/generations/$gen_number

if [[ ! -d "$gen_dir" ]]; then
  printf 'hod-ublue-build: generation directory not found: %s\n' "$gen_dir" >&2
  exit 1
fi

printf '[hod-ublue] using generation %s\n' "$gen_number" >&2

# ---------------------------------------------------------------------------
# 3. Collect closure hashes
# ---------------------------------------------------------------------------
metadata=$gen_dir/metadata.json
if [[ ! -f "$metadata" ]]; then
  printf 'hod-ublue-build: metadata.json not found in generation %s\n' "$gen_number" >&2
  exit 1
fi

if command -v jq >/dev/null 2>&1; then
  mapfile -t recipe_hashes < <(jq -r '.recipe_hashes[]' "$metadata")
else
  mapfile -t recipe_hashes < <(python3 -c "import json,sys; [print(h) for h in json.load(open('$metadata'))['recipe_hashes']]")
fi

if [[ ${#recipe_hashes[@]} -eq 0 ]]; then
  printf 'hod-ublue-build: no recipe hashes in generation metadata\n' >&2
  exit 1
fi

printf '[hod-ublue] %d top-level recipe hashes\n' "${#recipe_hashes[@]}" >&2

# ---------------------------------------------------------------------------
# 4. Copy closure into staging
# ---------------------------------------------------------------------------
printf '[hod-ublue] staging closure into %s\n' "$store_staging" >&2
rm -rf "$store_staging" "$system_staging" "$setup_staging"
mkdir -p "$store_staging" "$system_staging" "$setup_staging"

for hash in "${recipe_hashes[@]}"; do
  printf '[hod-ublue]   copying closure for %s\n' "${hash:0:12}" >&2
  "$hod_bin" copy-closure "$hash" --to "$store_staging" --force --quiet
done

# ---------------------------------------------------------------------------
# 5. Copy system generation and rewrite symlinks
# ---------------------------------------------------------------------------
printf '[hod-ublue] staging system generation\n' >&2

gen_dst=$system_staging/generations/$gen_number
mkdir -p "$gen_dst"

# Copy generation contents, excluding composefs data (not needed in OCI image)
for item in "$gen_dir"/*; do
  name=$(basename "$item")
  [[ "$name" == "composefs" ]] && continue
  cp -a "$item" "$gen_dst/"
done

ln -sf "generations/$gen_number" "$system_staging/current"

# Rewrite symlinks: host store paths → image store paths
rewrite_count=0
while IFS= read -r -d '' link; do
  target=$(readlink "$link")
  if [[ "$target" == "$host_store_root"* ]]; then
    new_target="${image_store}${target#"$host_store_root"}"
    rm -f "$link"
    ln -s "$new_target" "$link"
    rewrite_count=$((rewrite_count + 1))
  fi
done < <(find "$system_staging" -type l -print0)
printf '[hod-ublue] rewrote %d symlinks\n' "$rewrite_count" >&2

# Rewrite file contents that reference host store paths
sed_count=0
while IFS= read -r -d '' f; do
  if grep -q "$host_store_root" "$f" 2>/dev/null; then
    sed -i "s|$host_store_root|$image_store|g" "$f"
    sed_count=$((sed_count + 1))
  fi
done < <(find "$system_staging" -type f -print0)
printf '[hod-ublue] rewrote %d files with image paths\n' "$sed_count" >&2

if [[ "$stage_only" == true ]]; then
  printf '\n[hod-ublue] staging complete (--stage-only)\n' >&2
  printf '  store:  %s\n' "$store_staging" >&2
  printf '  system: %s\n' "$system_staging" >&2
  printf '  setup:  %s\n' "$setup_staging" >&2
  exit 0
fi

# ---------------------------------------------------------------------------
# 6. Setup script
# ---------------------------------------------------------------------------
cat > "$setup_staging/hod-setup.sh" <<'SETUPEOF'
#!/bin/bash
set -euo pipefail

gen=/usr/hod/system/current

# --- Create hod user ---
# base-main may not have video/render/audio/input groups.
# Create them via /etc/group directly to avoid depending on groupadd.
for entry in "video:44" "render:45" "audio:46" "input:47"; do
  grp="${entry%%:*}"
  gid="${entry##*:}"
  if ! getent group "$grp" >/dev/null 2>&1; then
    echo "${grp}:x:${gid}:" >> /etc/group
  fi
done

if ! id hod >/dev/null 2>&1; then
  echo "hod:x:1000:1000:Hod Desktop:/home/hod:/bin/bash" >> /etc/passwd
  echo "hod:x:1000:" >> /etc/group
  echo "hod:$(openssl passwd -6 hod)" >> /etc/shadow
  mkdir -p /var/home/hod
  chown 1000:1000 /var/home/hod
  usermod -aG wheel,video,render,audio,input hod 2>/dev/null || true
fi

HOD_HOME=/var/home/hod

# --- Home directory setup ---
mkdir -p "$HOD_HOME/.config/niri"
mkdir -p "$HOD_HOME/.local/share/niri"
mkdir -p "$HOD_HOME/.cache"
mkdir -p "$HOD_HOME/.local/state"

# Niri config
cat > "$HOD_HOME/.config/niri/config.kdl" <<'NIRICFG'
input {
    keyboard {
        xkb {
        }
    }
    touchpad {
        tap
        natural-scroll
    }
}

layout {
    gaps 12
    default-column-width { proportion 0.6; }
    focus-ring {
        width 3
        active-color "#7fc8ff"
        inactive-color "#505050"
    }
}

prefer-no-csd

spawn-at-startup "/usr/hod/system/current/pkgs/alacritty/bin/alacritty"
spawn-at-startup "/usr/hod/system/current/pkgs/mako-notify/bin/mako"

binds {
    Mod+T { spawn "/usr/hod/system/current/pkgs/alacritty/bin/alacritty"; }
    Mod+Return { spawn "/usr/hod/system/current/pkgs/alacritty/bin/alacritty"; }
    Mod+Shift+Return { spawn "/usr/hod/system/current/pkgs/alacritty/bin/alacritty"; }
    Ctrl+Alt+Return { spawn "/usr/hod/system/current/pkgs/alacritty/bin/alacritty"; }
    Mod+D { spawn "/usr/hod/system/current/pkgs/fuzzel/bin/fuzzel"; }
    Mod+Q { close-window; }
    Mod+Shift+E { quit; }
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }
    Mod+H     { focus-column-left; }
    Mod+L     { focus-column-right; }
    Mod+K     { focus-window-up; }
    Mod+J     { focus-window-down; }
    Mod+F     { maximize-column; }
}
NIRICFG

# Bash profile — auto-launch niri on tty1
cat > "$HOD_HOME/.bash_profile" <<'BPEOF'
[ -f ~/.bashrc ] && . ~/.bashrc

if [ "$(tty 2>/dev/null)" = "/dev/tty1" ] && [ -z "$WAYLAND_DISPLAY" ]; then
  export XDG_RUNTIME_DIR="/run/user/$(id -u)"
  export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
  export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
  export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
  export XDG_SESSION_TYPE=wayland
  export XDG_CURRENT_DESKTOP=niri
  export XDG_SESSION_DESKTOP=niri
  export DESKTOP_SESSION=niri
  export XCURSOR_THEME=Adwaita

  for _hod_fc in /usr/hod/store/staging/*/*/etc/fonts/fonts.conf; do
    [ -f "$_hod_fc" ] || continue
    export FONTCONFIG_FILE="$_hod_fc"
    break
  done
  unset _hod_fc

  mkdir -p "$XDG_RUNTIME_DIR" "$XDG_CONFIG_HOME" "$XDG_STATE_HOME" "$XDG_CACHE_HOME"
  mkdir -p "$HOME/.local/share/niri"
  chmod 700 "$XDG_RUNTIME_DIR" 2>/dev/null || true

  # Discover library dirs from all store staging outputs for dlopen() resolution
  _HOD_LD=""
  for _hod_lib in /usr/hod/store/staging/*/*/lib; do
    [ -d "$_hod_lib" ] || continue
    case ":$_HOD_LD:" in
      *:"$_hod_lib":*) ;;
      *) _HOD_LD="$_hod_lib${_HOD_LD:+:$_HOD_LD}" ;;
    esac
  done
  unset _hod_lib

  _HOD_DRI=""
  for _hod_d in /usr/hod/store/staging/*/*/lib/dri; do
    [ -d "$_hod_d" ] || continue
    _HOD_DRI="$_hod_d${_HOD_DRI:+:$_HOD_DRI}"
  done
  unset _hod_d

  _HOD_GBM=""
  for _hod_g in /usr/hod/store/staging/*/*/lib/gbm; do
    [ -d "$_hod_g" ] || continue
    _HOD_GBM="$_hod_g${_HOD_GBM:+:$_HOD_GBM}"
  done
  unset _hod_g

  _HOD_EGL=""
  for _hod_e in /usr/hod/store/staging/*/*/share/glvnd/egl_vendor.d; do
    [ -d "$_hod_e" ] || continue
    _HOD_EGL="$_hod_e${_HOD_EGL:+:$_HOD_EGL}"
  done
  unset _hod_e

  _HOD_XKB=""
  for _hod_x in /usr/hod/store/staging/*/*/share/X11/xkb; do
    [ -d "$_hod_x" ] || continue
    _HOD_XKB="$_hod_x"
    break
  done
  unset _hod_x

  _HOD_DATA=""
  for _hod_s in /usr/hod/system/current/pkgs/*/share /usr/hod/store/staging/*/*/share; do
    [ -d "$_hod_s" ] || continue
    _HOD_DATA="$_hod_s${_HOD_DATA:+:$_HOD_DATA}"
  done
  unset _hod_s

  export _HOD_LD _HOD_DRI _HOD_GBM _HOD_EGL _HOD_XKB _HOD_DATA
  exec dbus-run-session -- sh -lc '
    dbus-update-activation-environment --all 2>/dev/null || true
    export LD_LIBRARY_PATH="$_HOD_LD"
    export LIBGL_DRIVERS_PATH="$_HOD_DRI"
    export GBM_BACKENDS_PATH="$_HOD_GBM"
    export __EGL_VENDOR_LIBRARY_DIRS="$_HOD_EGL"
    export XKB_CONFIG_ROOT="$_HOD_XKB"
    export XDG_DATA_DIRS="${_HOD_DATA:+$_HOD_DATA:}/usr/share"
    export XCURSOR_THEME=Adwaita

    # Start PipeWire audio if available
    _pw_bin=""
    for _p in /usr/hod/system/current/pkgs/pipewire/bin/pipewire; do
      [ -x "$_p" ] || continue
      _pw_bin="$_p"
      break
    done
    if [ -n "$_pw_bin" ]; then
      _pw_dir=""
      for _pd in /usr/hod/store/staging/*/*/share/pipewire/pipewire.conf; do
        [ -f "$_pd" ] || continue
        _pw_dir="$(dirname "$(dirname "$(dirname "$_pd")")")"
        break
      done
      if [ -n "$_pw_dir" ]; then
        SPA_PLUGIN_DIR="$_pw_dir/lib/spa-0.2" \
        PIPEWIRE_CONFIG_DIR="$_pw_dir/share/pipewire" \
        PIPEWIRE_MODULE_DIR="$_pw_dir/lib/pipewire-0.3" \
        "$_pw_bin" &
        for _pp in /usr/hod/system/current/pkgs/pipewire/bin/pipewire-pulse; do
          [ -x "$_pp" ] && \
            SPA_PLUGIN_DIR="$_pw_dir/lib/spa-0.2" \
            PIPEWIRE_CONFIG_DIR="$_pw_dir/share/pipewire" \
            PIPEWIRE_MODULE_DIR="$_pw_dir/lib/pipewire-0.3" \
            "$_pp" &
        done
        for _wp in /usr/hod/system/current/pkgs/wireplumber/bin/wireplumber; do
          [ -x "$_wp" ] && "$_wp" &
        done
      fi
      unset _pw_bin _pp _wp _pw_dir
      sleep 0.5
    fi

    exec /usr/hod/system/current/pkgs/niri/bin/niri --session
  ' > "$HOME/.local/share/niri/hod-session.log" 2>&1
fi
BPEOF

# Minimal .bashrc
cat > "$HOD_HOME/.bashrc" <<'BRCEOF'
[ -f /etc/profile.d/hod.sh ] && . /etc/profile.d/hod.sh
BRCEOF

chown -R 1000:1000 "$HOD_HOME"
chmod 700 "$HOD_HOME"

# --- /etc/profile.d/hod.sh ---
if [ -d "$gen/pkgs" ]; then
  {
    printf '# Generated by hod-ublue-build.\n'
    printf 'HOD_SYSTEM_CURRENT=/usr/hod/system/current\n'
    printf 'for _hod_pkg in "$HOD_SYSTEM_CURRENT"/pkgs/*; do\n'
    printf '  if [ -d "$_hod_pkg/bin" ]; then\n'
    printf '    PATH="$_hod_pkg/bin${PATH:+:$PATH}"\n'
    printf '  fi\n'
    printf '  if [ -d "$_hod_pkg/share/man" ]; then\n'
    printf '    MANPATH="$_hod_pkg/share/man${MANPATH:+:$MANPATH}"\n'
    printf '  fi\n'
    printf '  if [ -d "$_hod_pkg/share" ]; then\n'
    printf '    XDG_DATA_DIRS="$_hod_pkg/share${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}"\n'
    printf '  fi\n'
    printf 'done\n'
    printf 'export PATH MANPATH XDG_DATA_DIRS HOD_SYSTEM_CURRENT\n'
    printf 'unset _hod_pkg\n'
  } > /etc/profile.d/hod.sh
fi

# --- Autologin on tty1 ---
mkdir -p /etc/systemd/system/getty@tty1.service.d
cat > /etc/systemd/system/getty@tty1.service.d/autologin.conf <<'AUTOEOF'
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin hod --noclear %I $TERM
AUTOEOF

# --- DRM udev rule ---
mkdir -p /etc/udev/rules.d
cat > /etc/udev/rules.d/50-drm.rules <<'EOF'
SUBSYSTEM=="drm", MODE="0666"
EOF

# --- Install systemd units from Hod packages ---
unit_count=0
if [ -d "$gen/pkgs" ]; then
  for pkg in "$gen"/pkgs/*; do
    [ -L "$pkg" ] || continue
    actual_pkg="$(readlink -f "$pkg")"
    unit_dir="$actual_pkg/lib/systemd/system"
    if [ -d "$unit_dir" ]; then
      for unit in "$unit_dir"/*.service; do
        [ -f "$unit" ] || continue
        unit_name=$(basename "$unit")
        cp "$unit" "/usr/lib/systemd/system/$unit_name"
        systemctl enable "$unit_name" 2>/dev/null || true
        unit_count=$((unit_count + 1))
      done
    fi
  done
fi
echo "hod-setup: installed $unit_count systemd unit(s)" || true

# --- Enable core services ---
systemctl enable sshd.service 2>/dev/null || systemctl enable sshd.socket 2>/dev/null || true

# --- Ensure tmpfiles creates runtime dirs ---
systemd-tmpfiles --create --prefix=/var/hod 2>/dev/null || true

echo "hod-setup: done"
SETUPEOF
chmod +x "$setup_staging/hod-setup.sh"

# ---------------------------------------------------------------------------
# 7. tmpfiles.d
# ---------------------------------------------------------------------------
mkdir -p "$staging_dir/tmpfiles"
cat > "$staging_dir/tmpfiles/hod.conf" <<'EOF'
# Hod runtime directories
d /var/hod 0755 root root -
d /var/hod/system 0755 root root -
L /var/hod/store - - - - /usr/hod/store
EOF

# ---------------------------------------------------------------------------
# 8. Generate Containerfile
# ---------------------------------------------------------------------------
{
  printf 'ARG BASE=%s\n' "$base_tag"
  printf 'FROM ${BASE}\n\n'

  printf 'LABEL containers.bootc=1\n\n'

  printf '# Hod content-addressed store\n'
  printf 'COPY hod-store/ %s/\n\n' "$image_store"

  printf '# Hod system profile generation + current symlink\n'
  printf 'COPY hod-system/ /usr/hod/system/\n\n'

  printf '# tmpfiles.d entries for runtime /var/hod\n'
  printf 'COPY tmpfiles/hod.conf /usr/lib/tmpfiles.d/hod.conf\n\n'

  printf '# Setup: user, session, services\n'
  printf 'COPY setup/hod-setup.sh /usr/local/bin/hod-setup.sh\n'
  printf 'RUN /usr/local/bin/hod-setup.sh\n\n'

  if [[ -n "$ssh_pubkey_text" ]]; then
    printf '# Authorize SSH key for root\n'
    printf 'RUN mkdir -p /var/roothome/.ssh && chmod 700 /var/roothome/.ssh && echo "%s" > /var/roothome/.ssh/authorized_keys && chmod 600 /var/roothome/.ssh/authorized_keys\n\n' "$ssh_pubkey_text"
  fi

  printf '# Verify bootc compatibility\n'
  printf 'RUN bootc container lint\n'
} > "$containerfile"

printf '[hod-ublue] generated Containerfile:\n' >&2
sed 's/^/  /' "$containerfile" >&2

# ---------------------------------------------------------------------------
# 9. Build the derived image
# ---------------------------------------------------------------------------
printf '[hod-ublue] building derived image %s\n' "$image_tag" >&2
podman build \
  --dns 8.8.8.8 --dns 1.1.1.1 \
  -f "$containerfile" -t "$image_tag" "$staging_dir"

printf '\n[hod-ublue] done\n' >&2
printf '  image: %s\n' "$image_tag" >&2
printf '  run:   scripts/hod-ublue-run\n' >&2
printf '  test:  just ublue-test\n' >&2
