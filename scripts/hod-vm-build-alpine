#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage: scripts/hod-vm-build-alpine

Create the first minimal Hod OS test VM image under .hod-vm/alpine/.

Environment:
  HOD_VM_STATE_DIR       VM state directory (default: .hod-vm/alpine)
  HOD_VM_IMAGE_SIZE      Final qcow2 size (default: 12G)
  HOD_VM_HOSTNAME        Guest hostname (default: hodvm)
  HOD_VM_USER            Guest user (default: hod)
  HOD_VM_PASSWORD        Guest/root password for local test VM (default: hod)
  HOD_VM_SSH_PUBKEY      SSH public key text to authorize for the guest user
  HOD_VM_SSH_PUBKEY_FILE SSH public key file (default: first existing id_*.pub)
  ALPINE_IMAGE_URL       Override upstream Alpine cloud image URL

The image is intentionally a tiny Alpine cloud-init base. It owns boot, init,
networking, SSH, rsync, and recovery login only; Hod owns normal userland.
USAGE
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'hod-vm-build-alpine: missing %s; run inside `nix develop --accept-flake-config`\n' "$1" >&2
    exit 1
  fi
}

need curl
need genisoimage
need qemu-img
need sha512sum

state_dir=${HOD_VM_STATE_DIR:-.hod-vm/alpine}
cache_dir=$state_dir/cache
seed_dir=$state_dir/seed
image_size=${HOD_VM_IMAGE_SIZE:-12G}
hostname=${HOD_VM_HOSTNAME:-hodvm}
guest_user=${HOD_VM_USER:-hod}
guest_password=${HOD_VM_PASSWORD:-hod}
alpine_url=${ALPINE_IMAGE_URL:-https://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/cloud/nocloud_alpine-3.23.4-x86_64-bios-cloudinit-r0.qcow2}
alpine_sha_url=${alpine_url}.sha512
archive=$cache_dir/${alpine_url##*/}
sha_file=$archive.sha512
base_image=$cache_dir/base.qcow2
disk_image=$state_dir/hod-alpine.qcow2
seed_iso=$state_dir/seed.iso

mkdir -p "$cache_dir" "$seed_dir"

if [[ ! -f "$archive" ]]; then
  printf '[hod-vm] downloading Alpine cloud image\n' >&2
  curl -L --fail -o "$archive" "$alpine_url"
fi

if [[ ! -f "$sha_file" ]]; then
  printf '[hod-vm] downloading Alpine image checksum\n' >&2
  curl -L --fail -o "$sha_file" "$alpine_sha_url"
fi

printf '[hod-vm] verifying Alpine image checksum\n' >&2
expected_sha=$(tr -d '[:space:]' < "$sha_file" | cut -c1-128)
actual_sha=$(sha512sum "$archive" | cut -d ' ' -f1)
if [[ -z "$expected_sha" || "$expected_sha" != "$actual_sha" ]]; then
  printf 'hod-vm-build-alpine: checksum mismatch for %s\n' "$archive" >&2
  printf '  expected: %s\n' "$expected_sha" >&2
  printf '  actual:   %s\n' "$actual_sha" >&2
  exit 1
fi

if [[ ! -f "$base_image" ]]; then
  printf '[hod-vm] preparing base qcow2 image\n' >&2
  case "$archive" in
    *.qcow2)
      cp "$archive" "$base_image"
      ;;
    *.raw.tar.gz)
      if ! command -v tar >/dev/null 2>&1; then
        printf 'hod-vm-build-alpine: tar is required for raw.tar.gz images\n' >&2
        exit 1
      fi
      rm -f "$cache_dir"/*.raw
      tar -xzf "$archive" -C "$cache_dir"
      raw_candidates=("$cache_dir"/*.raw)
      if [[ ! -f "${raw_candidates[0]}" ]]; then
        printf 'hod-vm-build-alpine: archive did not contain a .raw image\n' >&2
        exit 1
      fi
      qemu-img convert -f raw -O qcow2 "${raw_candidates[0]}" "$base_image"
      ;;
    *)
      printf 'hod-vm-build-alpine: unsupported Alpine image type: %s\n' "$archive" >&2
      exit 1
      ;;
  esac
fi

if [[ ! -f "$disk_image" ]]; then
  printf '[hod-vm] creating qcow2 disk %s\n' "$disk_image" >&2
  qemu-img convert -f qcow2 -O qcow2 "$base_image" "$disk_image"
  qemu-img resize "$disk_image" "$image_size"
else
  printf '[hod-vm] reusing existing disk %s\n' "$disk_image" >&2
fi

ssh_key=${HOD_VM_SSH_PUBKEY:-}
if [[ -z "$ssh_key" ]]; then
  key_file=${HOD_VM_SSH_PUBKEY_FILE:-}
  if [[ -z "$key_file" ]]; then
    for candidate in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub"; do
      if [[ -f "$candidate" ]]; then
        key_file=$candidate
        break
      fi
    done
  fi
  if [[ -n "$key_file" && -f "$key_file" ]]; then
    ssh_key=$(<"$key_file")
  fi
fi

authorized_keys_yaml="[]"
if [[ -n "$ssh_key" ]]; then
  authorized_keys_yaml="[\"$ssh_key\"]"
fi

cat > "$seed_dir/meta-data" <<EOF
instance-id: hod-alpine-001
local-hostname: $hostname
EOF

cat > "$seed_dir/user-data" <<EOF
#cloud-config
hostname: $hostname
manage_etc_hosts: true
ssh_pwauth: true
disable_root: false

users:
  - name: $guest_user
    groups: wheel
    shell: /bin/ash
    lock_passwd: false
    plain_text_passwd: "$guest_password"
    ssh_authorized_keys: $authorized_keys_yaml

chpasswd:
  expire: false
  users:
    - name: root
      password: "$guest_password"
      type: text
    - name: $guest_user
      password: "$guest_password"
      type: text

package_update: true
packages:
  - openssh
  - rsync

write_files:
  - path: /etc/doas.d/wheel.conf
    owner: root:root
    permissions: '0440'
    content: |
      permit nopass :wheel

runcmd:
  - rc-update add sshd default
  - rc-service sshd restart
  - mkdir -p /home/$guest_user/.hod /home/$guest_user/.local/share/hod
  - chown -R $guest_user:$guest_user /home/$guest_user/.hod /home/$guest_user/.local
  - grep -qxF '[ -f "\$HOME/.hod/profiles/minimal-vm/env.sh" ] && . "\$HOME/.hod/profiles/minimal-vm/env.sh"' /home/$guest_user/.profile || printf '\n[ -f "\$HOME/.hod/profiles/minimal-vm/env.sh" ] && . "\$HOME/.hod/profiles/minimal-vm/env.sh"\n' >> /home/$guest_user/.profile
  - chown $guest_user:$guest_user /home/$guest_user/.profile
EOF

printf '[hod-vm] creating cloud-init seed ISO\n' >&2
genisoimage -quiet -output "$seed_iso" -volid cidata -joliet -rock "$seed_dir/user-data" "$seed_dir/meta-data"

cat > "$state_dir/ssh-config" <<EOF
Host hod-vm
  HostName 10.10.0.6
  Port 2222
  User $guest_user
  StrictHostKeyChecking accept-new
  UserKnownHostsFile $state_dir/known_hosts
EOF

printf '[hod-vm] ready\n' >&2
printf '  disk: %s\n' "$disk_image"
printf '  seed: %s\n' "$seed_iso"
printf '  run:  scripts/hod-vm-run-alpine\n'
printf '  ssh:  ssh -F %s/ssh-config hod-vm\n' "$state_dir"
