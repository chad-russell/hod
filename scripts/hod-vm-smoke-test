#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage: scripts/hod-vm-smoke-test [PROFILE]

Run the VM smoke tests for one profile against an already-running VM.
This is a thin wrapper around the test framework in tests/vm/.

Default profile: minimal-vm.
Recognized profiles: minimal-vm, minimal-vm-dev, invariants.

For full lifecycle testing (boot + deploy + smoke + teardown) use
scripts/hod-vm-test instead.

Environment:
  HOD_VM_HOST       SSH host (default: 10.10.0.6)
  HOD_VM_SSH_PORT   SSH port (default: 2222)
  HOD_VM_USER       Guest user (default: hod)
USAGE
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

profile=${1:-minimal-vm}
case "$profile" in
  minimal-vm|minimal-vm-dev|invariants) ;;
  *)
    printf 'hod-vm-smoke-test: unknown profile/suite %q\n' "$profile" >&2
    usage
    exit 2
    ;;
esac

# Suite names match profile names in tests/vm/cases/. We --reuse the running
# VM and --skip-deploy so this script keeps acting as a "lightweight check
# against the current VM" tool. For a fresh validation pass use hod-vm-test.
shift || true
exec bun run tests/vm/index.ts \
  --reuse \
  --skip-deploy \
  --suite "$profile" \
  "$@"
