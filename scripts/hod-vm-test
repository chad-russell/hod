#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage: scripts/hod-vm-test [options]

Full-lifecycle Hod VM test runner. Boots the Alpine VM under qemu (snapshot
mode — base disk is never mutated), deploys the configured profiles, runs
the declarative smoke suites in tests/vm/cases/, then tears the VM down.
A JSON results artifact is written alongside human-readable output.

Run inside the project nix dev shell so qemu-system-x86_64 and bun are on
PATH:

  nix develop --accept-flake-config --command scripts/hod-vm-test

This script is a thin shim around tests/vm/index.ts. See `--help` on the TS
entry point for the full option list.
USAGE
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exec bun run tests/vm/index.ts --help
fi

if ! command -v bun >/dev/null 2>&1; then
  printf 'hod-vm-test: missing bun; run inside `nix develop --accept-flake-config`\n' >&2
  exit 1
fi
if ! command -v qemu-system-x86_64 >/dev/null 2>&1; then
  printf 'hod-vm-test: missing qemu-system-x86_64; run inside `nix develop --accept-flake-config`\n' >&2
  exit 1
fi

exec bun run tests/vm/index.ts "$@"
